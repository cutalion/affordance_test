<h1>Payments (<%= @total_count %>)</h1>

<div class="filter-form">
  <%= form_tag(admin_payments_path, method: :get) do %>
    <div>
      <label>Status</label>
      <%= select_tag :status, options_for_select([["All", ""], "pending", "held", "charged", "refunded"], params[:status]) %>
    </div>
    <div>
      <button type="submit">Filter</button>
    </div>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Request</th>
      <th>Client</th>
      <th>Amount</th>
      <th>Fee</th>
      <th>Status</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @payments.each do |payment| %>
      <tr>
        <td><%= link_to "##{payment.id}", admin_payment_path(payment) %></td>
        <td><%= link_to "##{payment.request_id}", admin_request_path(payment.request) %></td>
        <td><%= payment.request.client.name %></td>
        <td><%= number_with_precision(payment.amount_cents.to_f / 100, precision: 2) %> <%= payment.currency %></td>
        <td><%= number_with_precision(payment.fee_cents.to_f / 100, precision: 2) %> <%= payment.currency %></td>
        <td><span class="badge badge-<%= payment.status %>"><%= payment.status %></span></td>
        <td><%= payment.created_at&.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
    <% if @payments.empty? %>
      <tr><td colspan="7" style="text-align:center; color:#7f8c8d;">No payments found</td></tr>
    <% end %>
  </tbody>
</table>

<div class="pagination">
  Showing <%= @payments.length %> of <%= @total_count %> payments
</div>
