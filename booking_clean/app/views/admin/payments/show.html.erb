<%= link_to "&larr; Back to Payments".html_safe, admin_payments_path, class: "back-link" %>
<h1>Payment #<%= @payment.id %></h1>

<div class="detail-card" style="max-width:600px;">
  <h2>Payment Details</h2>
  <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value"><%= @payment.id %></span></div>
  <div class="detail-row"><span class="detail-label">Order</span><span class="detail-value"><%= link_to "##{@payment.order_id}", admin_order_path(@payment.order) %></span></div>
  <div class="detail-row"><span class="detail-label">Client</span><span class="detail-value"><%= link_to @payment.order.client.name, admin_client_path(@payment.order.client) %></span></div>
  <div class="detail-row"><span class="detail-label">Provider</span><span class="detail-value"><%= link_to @payment.order.provider.name, admin_provider_path(@payment.order.provider) %></span></div>
  <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="badge badge-<%= @payment.status %>"><%= @payment.status %></span></span></div>
  <div class="detail-row"><span class="detail-label">Amount</span><span class="detail-value"><%= number_with_precision(@payment.amount_cents.to_f / 100, precision: 2) %> <%= @payment.currency %></span></div>
  <div class="detail-row"><span class="detail-label">Fee</span><span class="detail-value"><%= number_with_precision(@payment.fee_cents.to_f / 100, precision: 2) %> <%= @payment.currency %></span></div>
  <div class="detail-row"><span class="detail-label">Held At</span><span class="detail-value"><%= @payment.held_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
  <div class="detail-row"><span class="detail-label">Charged At</span><span class="detail-value"><%= @payment.charged_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
  <div class="detail-row"><span class="detail-label">Refunded At</span><span class="detail-value"><%= @payment.refunded_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
  <div class="detail-row"><span class="detail-label">Created At</span><span class="detail-value"><%= @payment.created_at&.strftime("%Y-%m-%d %H:%M") %></span></div>
</div>
