<h1>Dashboard</h1>

<div class="stat-grid">
  <div class="stat-card">
    <div class="label">Clients</div>
    <div class="value"><%= @clients_count %></div>
  </div>
  <div class="stat-card">
    <div class="label">Providers</div>
    <div class="value"><%= @providers_count %></div>
  </div>
  <div class="stat-card">
    <div class="label">Total Revenue</div>
    <div class="value"><%= number_with_precision(@total_revenue_cents.to_f / 100, precision: 2) %></div>
  </div>
  <div class="stat-card">
    <div class="label">Total Fees</div>
    <div class="value"><%= number_with_precision(@total_fees_cents.to_f / 100, precision: 2) %></div>
  </div>
  <% %w[created created_accepted accepted started fulfilled declined missed canceled rejected].each do |state| %>
    <div class="stat-card">
      <div class="label">Requests <span class="badge badge-<%= state %>"><%= state.humanize %></span></div>
      <div class="value"><%= @requests_by_state[state] || 0 %></div>
    </div>
  <% end %>
</div>

<h2>Recent Requests</h2>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Client</th>
      <th>Provider</th>
      <th>State</th>
      <th>Scheduled</th>
      <th>Amount</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @recent_requests.each do |req| %>
      <tr>
        <td><%= link_to "##{req.id}", admin_request_path(req) %></td>
        <td><%= req.client.name %></td>
        <td><%= req.provider.name %></td>
        <td><span class="badge badge-<%= req.state %>"><%= req.state.humanize %></span></td>
        <td><%= req.scheduled_at&.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= number_with_precision(req.amount_cents.to_f / 100, precision: 2) %> <%= req.currency %></td>
        <td><%= req.created_at&.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
    <% if @recent_requests.empty? %>
      <tr><td colspan="7" style="text-align:center; color:#7f8c8d;">No requests yet</td></tr>
    <% end %>
  </tbody>
</table>
