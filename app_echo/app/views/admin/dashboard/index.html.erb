<h1>Dashboard</h1>

<div class="stat-grid">
  <div class="stat-card">
    <div class="label">Clients</div>
    <div class="value"><%= @clients_count %></div>
  </div>
  <div class="stat-card">
    <div class="label">Providers</div>
    <div class="value"><%= @providers_count %></div>
  </div>
  <% %w[draft published closed].each do |state| %>
    <div class="stat-card">
      <div class="label">Announcements <span class="badge badge-<%= state %>"><%= state.humanize %></span></div>
      <div class="value"><%= @announcements_by_state[state] || 0 %></div>
    </div>
  <% end %>
  <% %w[pending accepted in_progress completed declined expired canceled rejected].each do |state| %>
    <div class="stat-card">
      <div class="label">Requests <span class="badge badge-<%= state %>"><%= state.humanize %></span></div>
      <div class="value"><%= @requests_by_state[state] || 0 %></div>
    </div>
  <% end %>
</div>

<h2>Recent Announcements</h2>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Client</th>
      <th>Title</th>
      <th>State</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @recent_announcements.each do |announcement| %>
      <tr>
        <td><%= link_to "##{announcement.id}", admin_announcement_path(announcement) %></td>
        <td><%= announcement.client.name %></td>
        <td><%= announcement.title %></td>
        <td><span class="badge badge-<%= announcement.state %>"><%= announcement.state.humanize %></span></td>
        <td><%= announcement.created_at&.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
    <% if @recent_announcements.empty? %>
      <tr><td colspan="5" style="text-align:center; color:#7f8c8d;">No announcements yet</td></tr>
    <% end %>
  </tbody>
</table>

<h2>Recent Requests</h2>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Client</th>
      <th>Provider</th>
      <th>State</th>
      <th>Scheduled</th>
      <th>Amount</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @recent_requests.each do |request| %>
      <tr>
        <td><%= link_to "##{request.id}", admin_request_path(request) %></td>
        <td><%= request.client.name %></td>
        <td><%= request.provider.name %></td>
        <td><span class="badge badge-<%= request.state %>"><%= request.state.humanize %></span></td>
        <td><%= request.scheduled_at&.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= number_with_precision(request.amount_cents.to_f / 100, precision: 2) %> <%= request.currency %></td>
        <td><%= request.created_at&.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
    <% if @recent_requests.empty? %>
      <tr><td colspan="7" style="text-align:center; color:#7f8c8d;">No requests yet</td></tr>
    <% end %>
  </tbody>
</table>
