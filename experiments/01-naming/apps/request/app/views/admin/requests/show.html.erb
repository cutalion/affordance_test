<%= link_to "&larr; Back to Requests".html_safe, admin_requests_path, class: "back-link" %>
<h1>Request #<%= @the_request.id %></h1>

<div class="detail-grid">
  <div class="detail-card">
    <h2>Request Details</h2>
    <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value"><%= @the_request.id %></span></div>
    <div class="detail-row"><span class="detail-label">State</span><span class="detail-value"><span class="badge badge-<%= @the_request.state %>"><%= @the_request.state.humanize %></span></span></div>
    <div class="detail-row"><span class="detail-label">Client</span><span class="detail-value"><%= link_to @the_request.client.name, admin_client_path(@the_request.client) %></span></div>
    <div class="detail-row"><span class="detail-label">Provider</span><span class="detail-value"><%= link_to @the_request.provider.name, admin_provider_path(@the_request.provider) %></span></div>
    <div class="detail-row"><span class="detail-label">Scheduled At</span><span class="detail-value"><%= @the_request.scheduled_at&.strftime("%Y-%m-%d %H:%M") %></span></div>
    <div class="detail-row"><span class="detail-label">Duration</span><span class="detail-value"><%= @the_request.duration_minutes %> min</span></div>
    <div class="detail-row"><span class="detail-label">Location</span><span class="detail-value"><%= @the_request.location %></span></div>
    <div class="detail-row"><span class="detail-label">Amount</span><span class="detail-value"><%= number_with_precision(@the_request.amount_cents.to_f / 100, precision: 2) %> <%= @the_request.currency %></span></div>
    <div class="detail-row"><span class="detail-label">Notes</span><span class="detail-value"><%= @the_request.notes %></span></div>
    <div class="detail-row"><span class="detail-label">Started At</span><span class="detail-value"><%= @the_request.started_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
    <div class="detail-row"><span class="detail-label">Completed At</span><span class="detail-value"><%= @the_request.completed_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
    <% if @the_request.cancel_reason.present? %>
      <div class="detail-row"><span class="detail-label">Cancel Reason</span><span class="detail-value"><%= @the_request.cancel_reason %></span></div>
    <% end %>
    <% if @the_request.reject_reason.present? %>
      <div class="detail-row"><span class="detail-label">Reject Reason</span><span class="detail-value"><%= @the_request.reject_reason %></span></div>
    <% end %>
    <div class="detail-row"><span class="detail-label">Created At</span><span class="detail-value"><%= @the_request.created_at&.strftime("%Y-%m-%d %H:%M") %></span></div>
  </div>

  <div>
    <% if @the_request.payment %>
      <div class="detail-card" style="margin-bottom:24px;">
        <h2>Payment</h2>
        <div class="detail-row"><span class="detail-label">Payment ID</span><span class="detail-value"><%= link_to @the_request.payment.id, admin_payment_path(@the_request.payment) %></span></div>
        <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="badge badge-<%= @the_request.payment.status %>"><%= @the_request.payment.status %></span></span></div>
        <div class="detail-row"><span class="detail-label">Amount</span><span class="detail-value"><%= number_with_precision(@the_request.payment.amount_cents.to_f / 100, precision: 2) %> <%= @the_request.payment.currency %></span></div>
        <div class="detail-row"><span class="detail-label">Fee</span><span class="detail-value"><%= number_with_precision(@the_request.payment.fee_cents.to_f / 100, precision: 2) %> <%= @the_request.payment.currency %></span></div>
        <div class="detail-row"><span class="detail-label">Held At</span><span class="detail-value"><%= @the_request.payment.held_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
        <div class="detail-row"><span class="detail-label">Charged At</span><span class="detail-value"><%= @the_request.payment.charged_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
        <div class="detail-row"><span class="detail-label">Refunded At</span><span class="detail-value"><%= @the_request.payment.refunded_at&.strftime("%Y-%m-%d %H:%M") || "—" %></span></div>
      </div>
    <% end %>

    <% if @the_request.reviews.any? %>
      <div class="detail-card">
        <h2>Reviews</h2>
        <% @the_request.reviews.each do |review| %>
          <div style="padding: 12px 0; border-bottom: 1px solid #f0f2f5;">
            <div style="font-size:13px; color:#7f8c8d; margin-bottom:4px;"><%= review.author_type %> &mdash; Rating: <%= review.rating %>/5</div>
            <div><%= review.comment %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
