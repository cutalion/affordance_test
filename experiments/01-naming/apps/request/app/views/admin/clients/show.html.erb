<%= link_to "&larr; Back to Clients".html_safe, admin_clients_path, class: "back-link" %>
<h1><%= @client.name %></h1>

<div class="detail-grid">
  <div class="detail-card">
    <h2>Client Details</h2>
    <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value"><%= @client.id %></span></div>
    <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value"><%= @client.name %></span></div>
    <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value"><%= @client.email %></span></div>
    <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value"><%= @client.phone %></span></div>
    <div class="detail-row"><span class="detail-label">Registered</span><span class="detail-value"><%= @client.created_at&.strftime("%Y-%m-%d %H:%M") %></span></div>
  </div>

  <div class="detail-card">
    <h2>Payment Cards</h2>
    <% if @cards.any? %>
      <% @cards.each do |card| %>
        <div class="detail-row">
          <span class="detail-label"><%= card.brand.upcase %> *<%= card.last_four %></span>
          <span class="detail-value"><%= card.exp_month %>/<%= card.exp_year %><% if card.default? %> <strong>(default)</strong><% end %></span>
        </div>
      <% end %>
    <% else %>
      <p style="color:#7f8c8d; font-size:14px;">No cards on file</p>
    <% end %>
  </div>
</div>

<h2>Recent Requests</h2>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Provider</th>
      <th>State</th>
      <th>Scheduled</th>
      <th>Amount</th>
    </tr>
  </thead>
  <tbody>
    <% @recent_requests.each do |req| %>
      <tr>
        <td><%= link_to "##{req.id}", admin_request_path(req) %></td>
        <td><%= req.provider.name %></td>
        <td><span class="badge badge-<%= req.state %>"><%= req.state.humanize %></span></td>
        <td><%= req.scheduled_at&.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= number_with_precision(req.amount_cents.to_f / 100, precision: 2) %> <%= req.currency %></td>
      </tr>
    <% end %>
    <% if @recent_requests.empty? %>
      <tr><td colspan="5" style="text-align:center; color:#7f8c8d;">No requests</td></tr>
    <% end %>
  </tbody>
</table>
