<h1>Announcements (<%= @total_count %>)</h1>

<div class="filter-form">
  <%= form_tag(admin_announcements_path, method: :get) do %>
    <div>
      <label>State</label>
      <%= select_tag :state, options_for_select([["All", ""], "draft", "published", "closed"], params[:state]) %>
    </div>
    <div>
      <button type="submit">Filter</button>
    </div>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Client</th>
      <th>Title</th>
      <th>State</th>
      <th>Budget</th>
      <th>Responses</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @announcements.each do |announcement| %>
      <tr>
        <td><%= link_to "##{announcement.id}", admin_announcement_path(announcement) %></td>
        <td><%= link_to announcement.client.name, admin_client_path(announcement.client) %></td>
        <td><%= announcement.title %></td>
        <td><span class="badge badge-<%= announcement.state %>"><%= announcement.state.humanize %></span></td>
        <td><%= announcement.budget_cents ? "#{number_with_precision(announcement.budget_cents.to_f / 100, precision: 2)} #{announcement.currency}" : "---" %></td>
        <td><%= announcement.requests.count %></td>
        <td><%= announcement.created_at&.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
    <% if @announcements.empty? %>
      <tr><td colspan="7" style="text-align:center; color:#7f8c8d;">No announcements found</td></tr>
    <% end %>
  </tbody>
</table>

<div class="pagination">
  Showing <%= @announcements.length %> of <%= @total_count %> announcements
</div>
