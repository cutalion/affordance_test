<h1>Orders (<%= @total_count %>)</h1>

<div class="filter-form">
  <%= form_tag(admin_orders_path, method: :get) do %>
    <div>
      <label>State</label>
      <%= select_tag :state, options_for_select([["All", ""], "pending", "confirmed", "in_progress", "completed", "canceled", "rejected"], params[:state]), class: "" %>
    </div>
    <div>
      <label>From</label>
      <%= date_field_tag :from, params[:from] %>
    </div>
    <div>
      <label>To</label>
      <%= date_field_tag :to, params[:to] %>
    </div>
    <div>
      <button type="submit">Filter</button>
    </div>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Client</th>
      <th>Provider</th>
      <th>State</th>
      <th>Scheduled</th>
      <th>Amount</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @orders.each do |order| %>
      <tr>
        <td><%= link_to "##{order.id}", admin_order_path(order) %></td>
        <td><%= link_to order.client.name, admin_client_path(order.client) %></td>
        <td><%= link_to order.provider.name, admin_provider_path(order.provider) %></td>
        <td><span class="badge badge-<%= order.state %>"><%= order.state.humanize %></span></td>
        <td><%= order.scheduled_at&.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= number_with_precision(order.amount_cents.to_f / 100, precision: 2) %> <%= order.currency %></td>
        <td><%= order.created_at&.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
    <% if @orders.empty? %>
      <tr><td colspan="7" style="text-align:center; color:#7f8c8d;">No orders found</td></tr>
    <% end %>
  </tbody>
</table>

<div class="pagination">
  Showing <%= @orders.length %> of <%= @total_count %> orders
</div>
